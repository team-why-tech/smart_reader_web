{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=smreader_master;Uid=root;Pwd=yourpassword;"
  },
  "Jwt": {
    "Key": "YOUR_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG!!",
    "Issuer": "SmreaderAPI",
    "Audience": "SmreaderAPI",
    "AccessTokenExpiryMinutes": 30,
    "RefreshTokenExpiryDays": 7
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Cache": {
    "L1ExpiryMinutes": 5,
    "L2ExpiryMinutes": 30
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://yourdomain.com" ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "*", "Period": "1m", "Limit": 100 },
      { "Endpoint": "post:/api/auth/*", "Period": "1m", "Limit": 10 }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/log-.txt", "rollingInterval": "Day" } }
    ]
  },
  "AllowedHosts": "*"
}
